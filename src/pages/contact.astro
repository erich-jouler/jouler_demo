---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Jouler. Direct email to the founder, no forms or routing."
>

  <!-- Hero -->
  <section class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-24 pt-24 pb-20">
    <p class="text-xs font-medium tracking-widest uppercase text-[#356B4F] mb-6">Contact</p>
    <h1 class="font-display text-5xl md:text-6xl font-light leading-[1.05] tracking-tight text-[#0A0A0A] max-w-xl">
      Get in touch.
    </h1>
    <p class="mt-6 text-lg text-[#525252] max-w-xl leading-relaxed">
      We like talking about thermal networks, so reach out if you're working on one.
    </p>
  </section>

  <!-- Direct contact -->
  <section class="bg-[#1A3D2B]">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-24 py-20">
      <div class="space-y-6">
        <a
          href="mailto:erich@jouler.net"
          class="block font-mono text-3xl md:text-4xl text-[#EAF2ED] hover:text-white transition-colors"
        >
          erich@jouler.net
        </a>
        <a
          href="https://linkedin.com/in/erich-ryan"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block text-sm text-[#7AAD8C] hover:text-[#EAF2ED] transition-colors"
        >
          LinkedIn →
        </a>
      </div>
    </div>
  </section>

  <!-- What to tell us -->
  <section class="bg-[#EEF5F0]">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-24 py-20">
      <div class="grid md:grid-cols-[2fr_3fr] gap-12 lg:gap-24 items-start">
        <div>
          <p class="text-xs font-medium tracking-widest uppercase text-[#356B4F] mb-4">Context helps</p>
          <h2 class="font-display text-2xl md:text-3xl font-light leading-tight text-[#0A0A0A]">
            Who we hear from
          </h2>
        </div>
        <div class="space-y-6 text-[#525252] leading-relaxed">
          <p>
            If you're working through whether a thermal network makes sense for a specific site,
            community, or utility territory, tell us where you are in that process and what you're
            trying to figure out.
          </p>
          <p>
            If you work in policy, project finance, or research touching TENs, we're glad to connect
            with others in the space.
          </p>
          <p>
            If you're a journalist or researcher covering the category, we're available to talk on
            background or on the record.
          </p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
